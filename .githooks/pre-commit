#!/usr/bin/env bash
#
# pre-commit — run the test suite before allowing a commit.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Skip for a single commit (use sparingly):  git commit --no-verify

set -euo pipefail

if [[ -x ".venv/bin/python" ]]; then
  PY=".venv/bin/python"
else
  PY="python3"
fi

echo "pre-commit: running test suite..."
if ! "$PY" -m unittest discover -s tests >/tmp/phenofit-precommit.log 2>&1; then
  echo "pre-commit: tests FAILED — commit aborted. Details:" >&2
  cat /tmp/phenofit-precommit.log >&2
  echo "(bypass with 'git commit --no-verify' if you know what you're doing)" >&2
  exit 1
fi
echo "pre-commit: tests passed."
