# Copy to .env and fill in. .env is gitignored.
# The Anthropic key is OPTIONAL: without it, PhenoFit still runs end to end —
# you just enter the reported variants and patient features by hand instead of
# dropping a lab-report PDF or pasting clinical notes for the AI edge to read.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (claude-sonnet-5).
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional: a licensed OMIM API key (register at https://omim.org/api) turns on
# OMIM corroboration — each fit is confirmed against OMIM's curated gene->disease
# catalogue, surfacing the inheritance pattern. Without it the review runs
# unchanged; OMIM is corroborative and never affects the ranking.
# OMIM_API_KEY=...

# AlphaGenome non-coding/splicing scoring (optional, Task 3). Free research key at
# https://deepmind.google.com/science/alphagenome
# ALPHAGENOME_API_KEY=
